{
  "version": 2,
  "framework": null,
  "buildCommand": "node setup-fonts.js",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/view", "destination": "/view.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/render.js": {
      "maxDuration": 60,
      "includeFiles": "fonts/**"
    },
    "api/generate.js": {
      "maxDuration": 30
    },
    "api/links/create.js": {
      "maxDuration": 10
    },
    "api/links/verify.js": {
      "maxDuration": 10
    },
    "api/links/list.js": {
      "maxDuration": 10
    },
    "api/links/manage.js": {
      "maxDuration": 10
    }
  }
}
